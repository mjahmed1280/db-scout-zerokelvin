# Frontend Configuration
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=8501

# Backend Configuration
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Database Configuration (Defaults for sidebar)
DB_TYPE=postgresql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=hackfest_db
DB_USER=hackfest
DB_PASSWORD=hackfest123

# Logging
LOG_DIRECTORY=./logs
LOG_LEVEL=INFO

# UI Configuration
CHAT_HISTORY_LIMIT=50
LOGS_DISPLAY_LIMIT=30
STREAM_TIMEOUT=60

# Feature Flags
ENABLE_ADVANCED_VISUALIZATIONS=true
ENABLE_REAL_TIME_LOGS=true
ENABLE_CHAT_STREAMING=true

# Styling
THEME=dark
PRIMARY_COLOR=#0ea5e9
SECONDARY_COLOR=#06b6d4
